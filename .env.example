# Notion OAuth (add these in Vercel Environment Variables)
# Get values from: https://www.notion.so/my-integrations
NOTION_CLIENT_ID=your_notion_client_id
NOTION_CLIENT_SECRET=your_notion_client_secret

# Optional: Override site URL for sitemap (Vercel sets VERCEL_URL automatically)
# SITE_URL=https://nicochikuji-portfolio.vercel.app

# Optional: GitHub personal access token (read:user scope) to show real contribution activity in the portfolio
# Without this, a decorative grid is shown with a link to your GitHub profile.
# VITE_GITHUB_TOKEN=ghp_xxxx
